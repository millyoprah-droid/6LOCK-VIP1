# TradingView API Configuration
TRADINGVIEW_API_KEY=your_tradingview_api_key
TRADINGVIEW_USERNAME=your_username
TRADINGVIEW_PASSWORD=your_password

# Trading Configuration
BROKER_API_KEY=your_broker_api_key
BROKER_SECRET=your_broker_secret
BROKER_ACCOUNT_ID=your_account_id

# Bot Settings
CONFIDENCE_THRESHOLD=80
RISK_REWARD_RATIO=4
BASE_RISK_PERCENT=1
TRADE_SIZE=1.0

# Timeframes to Monitor
TIMEFRAMES=15m,30m,1h,2h,4h,1d,1w

# Alert Settings
ALERT_EMAIL=your_email@gmail.com
ALERT_WEBHOOK=your_webhook_url

# Server Configuration
PORT=3000
ENV=development
AUTO_TRADE=false
